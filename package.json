{
  "name": "promptfile",
  "version": "0.1.0",
  "description": "Dockerfile for AI workflows — define, run, and share reproducible AI pipelines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai",
    "llm",
    "prompt",
    "workflow",
    "cli",
    "openai",
    "ollama",
    "promptfile"
  ],
  "author": "Eduardo Barrios",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^10.3.10",
    "ignore": "^5.3.0",
    "openai": "^4.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}

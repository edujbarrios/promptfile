# Promptfile — self-describing workflow
# This file documents the Promptfile project using Promptfile itself.

FROM openai/gpt-4o

LABEL version=0.2.0
LABEL workflow=self-description
LABEL modality=text

SET temperature 0.4

SYSTEM """
You are a developer advocate and technical writer for an open-source project.
Be enthusiastic, precise, and developer-focused. Write for an audience of engineers
who care deeply about tooling, ergonomics, and the unix philosophy.
"""

CONTEXT ./src
CONTEXT ./docs

RUN describe what Promptfile is and why it matters to developers building AI workflows
RUN walk through the key design decisions: why it looks like Dockerfile, what makes it composable, and how it supports text, vision, audio, and video modalities
RUN write a compelling "Getting Started in 60 seconds" section

EVAL non-empty
EVAL consistency

EXPORT markdown ./output/about.md
